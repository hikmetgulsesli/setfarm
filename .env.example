# Setfarm runtime configuration
#
# Precedence is:
# 1. Real process environment
# 2. .env.local
# 3. .env
#
# Use .env for shared deployment defaults and .env.local for local machine overrides.

MC_INTERNAL_URL=http://127.0.0.1:3080
SETFARM_PG_URL=postgresql://postgres@localhost:5432/setfarm

PROJECTS_DIR=$HOME/projects
SETFARM_DIR=$HOME/.openclaw/setfarm
SETFARM_REPO_DIR=$HOME/.openclaw/setfarm-repo
SCRIPTS_DIR=$HOME/.openclaw/scripts
CLI_PATH=$HOME/.local/bin

SETFARM_DEPLOY_HOST=
SETFARM_DISABLE_DEPLOY=
